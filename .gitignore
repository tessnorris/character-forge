# Dependencies — regenerated by `npm install` from package-lock.json; huge and platform-specific
node_modules/

# Build output — regenerated by `npm run build`
dist/

# Vite's internal cache
.vite/

# Test/coverage artifacts (if you add coverage reporting later)
coverage/

# Editor/OS cruft
.DS_Store
*.swp
.vscode/*
!.vscode/extensions.json

# Env files — anything with real secrets/config should never be committed
.env
.env.local
.env.*.local

# npm/yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
